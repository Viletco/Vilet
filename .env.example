# Public, client-safe canonical site origin.
NEXT_PUBLIC_SITE_URL=https://vilet.co

# Contact delivery: disabled (safe default) or resend.
CONTACT_DELIVERY_MODE=disabled
# Required only when CONTACT_DELIVERY_MODE=resend. Never commit real values.
RESEND_API_KEY=
CONTACT_FORM_RECIPIENT=
CONTACT_FROM_EMAIL=
CONTACT_REPLY_TO_MODE=submitted-email

# Abuse control: memory (local/single instance) or upstash (production shared).
CONTACT_RATE_LIMIT_MODE=memory
# Required only when CONTACT_RATE_LIMIT_MODE=upstash. Never commit real values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CONTACT_RATE_LIMIT_SALT=
