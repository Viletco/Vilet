# Public, client-safe canonical site origin.
NEXT_PUBLIC_SITE_URL=https://vilet.co

# Contact delivery: disabled (safe default) or resend.
CONTACT_DELIVERY_MODE=disabled
# Required only when CONTACT_DELIVERY_MODE=resend. Never commit real values.
RESEND_API_KEY=
CONTACT_FORM_RECIPIENT=
CONTACT_FROM_EMAIL=
CONTACT_REPLY_TO_MODE=submitted-email

# Abuse control: memory (local/single instance) or upstash (production shared).
CONTACT_RATE_LIMIT_MODE=memory
# Required only when CONTACT_RATE_LIMIT_MODE=upstash. Never commit real values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CONTACT_RATE_LIMIT_SALT=

# Vilét AI remains disabled until provider, privacy, cost, and launch approvals.
AI_ASSISTANT_MODE=disabled
AI_PROVIDER=none
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=
AI_PROVIDER_TIMEOUT_MS=12000
AI_MAX_OUTPUT_TOKENS=700

# AI abuse control: memory for local/preview; approved Upstash for public production.
AI_CHAT_RATE_LIMIT_MODE=memory
AI_CHAT_RATE_LIMIT_SALT=
AI_CHAT_UPSTASH_REDIS_REST_URL=
AI_CHAT_UPSTASH_REDIS_REST_TOKEN=

# Insights and public website fetching remain disabled by default.
AI_INSIGHTS_MODE=disabled
AI_WEBSITE_ANALYZER_MODE=disabled
